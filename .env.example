# ============================================================
#  Forager — esempio configurazione
#  Copia questo file come .env e modifica i valori che ti servono.
#  Tutti i valori sono OPZIONALI: Forager funziona out-of-the-box.
# ============================================================

# --- Sicurezza ---
# Una stringa segreta usata per i cookie di sessione.
# In produzione mettila lunga e random. In locale puoi lasciare il default.
FORAGER_SECRET_KEY=cambia-questa-stringa-in-qualcosa-di-random

# --- Server ---
# Tieni 127.0.0.1 (solo questo computer). Usa 0.0.0.0 SOLO su reti fidate:
# espone l'app a tutta la rete locale.
FORAGER_HOST=127.0.0.1
FORAGER_PORT=5000
# DEBUG: lascia 0. Mettilo a 1 SOLO mentre sviluppi e MAI con HOST=0.0.0.0
# (con debug attivo un errore apre una console che esegue codice).
FORAGER_DEBUG=0

# --- Hunter.io (OPZIONALE) ---
# Per trovare email dei decision maker. Registrati gratis su https://hunter.io
# Free tier: 25 searches/mese, 50 verifications/mese.
# Lascia vuoto se non vuoi usare Hunter — Forager funziona comunque.
HUNTER_API_KEY=
HUNTER_SENIORITY=executive    # executive | senior | junior (comma-sep)
HUNTER_MAX_PER_DOMAIN=25
HUNTER_CACHE_DAYS=30

# --- Claude CLI ---
# Path al binary `claude`. Lascia vuoto per auto-detect dal PATH.
# Esempio: /opt/homebrew/bin/claude  oppure  /usr/local/bin/claude
CLAUDE_BIN=
